#!/usr/bin/env bash
# Setup local environment.
# Idempotent. Safe to run in CI without secrets.
# DB migration is intentionally NOT run here (Neon is shared infra).
set -euo pipefail

cd "$(dirname "$0")/.."

if [[ ! -f .dev.vars && -f .dev.vars.example ]]; then
  echo "warn: .dev.vars is missing. Copy .dev.vars.example and fill in local secrets." >&2
fi

npm ci
